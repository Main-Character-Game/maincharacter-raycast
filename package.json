{
  "name": "maincharacter-raycast",
  "version": "0.1.0",
  "description": "Quickly add tasks to Main Character from Raycast.",
  "license": "MIT",
  "main": "src/quick-add-task.tsx",
  "scripts": {
    "dev": "ray develop",
    "build": "ray build",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "ci:quality": "npm run checks:shared && npm run lint && npm run test && npm run build",
    "checks:shared": "node scripts/check-shared-review-scripts.mjs",
    "checks:shared:sync": "scripts/sync-shared-review-scripts.sh",
    "ai:review:last": "scripts/codex-review-last-commit",
    "setup:githooks": "scripts/setup-githooks",
    "prepare": "husky"
  },
  "dependencies": {
    "@raycast/api": "^1.102.0",
    "@raycast/utils": "^1.17.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.0",
    "@types/react": "19.0.10",
    "eslint": "^9.20.1",
    "husky": "^9.1.7",
    "prettier": "^3.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  },
  "schemaVersion": 1,
  "title": "Main Character",
  "author": "gmays",
  "icon": "main-character-icon.png",
  "categories": [
    "Productivity"
  ],
  "keywords": [
    "main character",
    "tasks",
    "quick add",
    "capture",
    "todo"
  ],
  "preferences": [
    {
      "name": "baseUrl",
      "title": "API Base URL",
      "description": "Main Character base URL",
      "type": "textfield",
      "required": true,
      "default": "https://maincharacter.game"
    },
    {
      "name": "personalAccessToken",
      "title": "Personal Access Token",
      "description": "PAT with TASK_CREATE scope",
      "type": "password",
      "required": true
    }
  ],
  "commands": [
    {
      "name": "quick-add-task",
      "title": "Quick Add Task",
      "subtitle": "Create in Main Character",
      "description": "Capture a task quickly from Raycast",
      "mode": "view",
      "icon": "quick-add-task-icon.png",
      "keywords": [
        "add",
        "create",
        "capture",
        "task"
      ],
      "arguments": [
        {
          "name": "title",
          "placeholder": "Optional title prefill",
          "type": "text",
          "required": false
        }
      ]
    }
  ]
}
