#!/usr/bin/env node

import { existsSync } from "node:fs";
import { chmod, mkdir, readFile, rm, writeFile } from "node:fs/promises";
import { join } from "node:path";
import { spawnSync } from "node:child_process";

function usage() {
  console.log("Usage: scripts/codex-review-commit --sha <commit-sha> --trigger <post-commit|post-push|manual>");
}

function parseArgs(argv) {
  const args = { sha: "", trigger: "" };
  for (let i = 2; i < argv.length; i += 1) {
    const arg = argv[i];
    const next = argv[i + 1];
    if (arg === "--sha") {
      args.sha = String(next ?? "");
      i += 1;
    } else if (arg === "--trigger") {
      args.trigger = String(next ?? "");
      i += 1;
    } else if (arg === "-h" || arg === "--help") {
      usage();
      process.exit(0);
    }
  }
  return args;
}

function run(cmd, args, options = {}) {
  return spawnSync(cmd, args, { encoding: "utf8", ...options });
}

function commandExists(command) {
  const result = run("sh", ["-lc", `command -v ${command} >/dev/null 2>&1`]);
  return result.status === 0;
}

function severityRank(severity) {
  if (severity === "blocker") return 3;
  if (severity === "major") return 2;
  return 1;
}

function normalizeFinding(input, index, sourceModel) {
  const id = typeof input?.id === "string" && input.id.trim() ? input.id.trim() : `${sourceModel}-f-${index + 1}`;
  const title = typeof input?.title === "string" ? input.title.trim() : "";
  const severityRaw = typeof input?.severity === "string" ? input.severity.toLowerCase().trim() : "minor";
  const severity = ["minor", "major", "blocker"].includes(severityRaw) ? severityRaw : "minor";
  const confidence = Number.isFinite(input?.confidence) ? Math.max(0, Math.min(1, Number(input.confidence))) : 0.5;
  const file = typeof input?.file === "string" && input.file.trim() ? input.file.trim() : null;
  const line = Number.isInteger(input?.line) && input.line > 0 ? input.line : null;
  const body = typeof input?.body === "string" ? input.body.trim() : "";
  if (!title || !body) return null;

  return {
    id,
    title,
    severity,
    confidence,
    file,
    line,
    body,
    source_model: sourceModel,
  };
}

function extractJsonObject(text) {
  const start = text.indexOf("{");
  const end = text.lastIndexOf("}");
  if (start === -1 || end === -1 || end <= start) {
    throw new Error("no JSON object found in model output");
  }
  return text.slice(start, end + 1);
}

function dedupeFindings(findings) {
  const map = new Map();
  for (const finding of findings) {
    const key = `${finding.title}::${finding.file ?? ""}::${finding.line ?? ""}::${finding.severity}`;
    const existing = map.get(key);
    if (!existing || finding.confidence > existing.confidence) {
      map.set(key, finding);
    }
  }
  return [...map.values()].sort((a, b) => {
    const sevDelta = severityRank(b.severity) - severityRank(a.severity);
    if (sevDelta !== 0) return sevDelta;
    return b.confidence - a.confidence;
  });
}

function buildPrompt({ sha, patch }) {
  return [
    "You are a strict code reviewer. Review this single commit patch.",
    "Focus on correctness, security, reliability, and regressions.",
    "Return ONLY JSON with shape:",
    '{"schema_version":2,"summary":"...","findings":[{"id":"...","title":"...","severity":"minor|major|blocker","confidence":0.0,"file":"path|nullable","line":1,"body":"..."}]}',
    "Do not include markdown fences.",
    `Commit SHA: ${sha}`,
    "Patch:",
    patch,
  ].join("\n\n");
}

function buildFallback(summary, metadata = {}) {
  return {
    schema_version: 2,
    summary,
    findings: [],
    metadata,
  };
}

async function writeMarkdown(path, sha, summary, findings, metadata) {
  const lines = [];
  lines.push(`# Codex Review Action Needed: ${sha}`);
  lines.push("");
  lines.push(summary);
  lines.push("");
  lines.push(`- trigger: ${metadata.trigger}`);
  lines.push(`- generated_at: ${metadata.generated_at}`);
  lines.push(`- codex_status: ${metadata.codex_status}`);
  lines.push(`- qwen_status: ${metadata.qwen_status}`);
  lines.push("");

  if (findings.length === 0) {
    lines.push("No actionable findings.");
  } else {
    lines.push("## Findings");
    lines.push("");
    for (const finding of findings) {
      const location = finding.file ? ` (${finding.file}${finding.line ? `:${finding.line}` : ""})` : "";
      lines.push(`### [${finding.id}] [${finding.severity.toUpperCase()}] ${finding.title}${location}`);
      lines.push(`- confidence: ${finding.confidence.toFixed(2)}`);
      lines.push(`- source: ${finding.source_model ?? "unknown"}`);
      lines.push(`- ${finding.body}`);
      lines.push("");
    }
  }

  await writeFile(path, `${lines.join("\n")}\n`, "utf8");
}

async function main() {
  if ((process.env.CODEX_REVIEW_ENABLED ?? "1") === "0") {
    process.exit(0);
  }

  const args = parseArgs(process.argv);
  if (!args.sha || !args.trigger) {
    usage();
    process.exit(2);
  }

  if (!["post-commit", "post-push", "manual"].includes(args.trigger)) {
    throw new Error(`invalid trigger: ${args.trigger}`);
  }

  const repoRoot = process.cwd();
  const shaCheck = run("git", ["rev-parse", "--verify", "--quiet", `${args.sha}^{commit}`]);
  if (shaCheck.status !== 0) {
    throw new Error(`commit not found: ${args.sha}`);
  }

  const reviewsDir = process.env.CODEX_REVIEW_DIR?.trim() || join(repoRoot, ".codex", "reviews");
  await mkdir(reviewsDir, { recursive: true, mode: 0o700 });
  try {
    await chmod(reviewsDir, 0o700);
  } catch {
    // no-op
  }

  const schemaPath = join(repoRoot, "scripts", "codex-review-output.schema.json");
  const jsonPath = join(reviewsDir, `${args.sha}.json`);
  const mdPath = join(reviewsDir, `${args.sha}.md`);
  const tmpCodexPath = join(reviewsDir, `${args.sha}.${Date.now()}.codex.json`);

  const show = run("git", ["show", "--patch", "--unified=3", "--format=fuller", args.sha], { maxBuffer: 20 * 1024 * 1024 });
  const patch = show.status === 0 ? show.stdout : "";
  const prompt = buildPrompt({ sha: args.sha, patch });

  const reviewTimeout = Number.parseInt(process.env.CODEX_REVIEW_TIMEOUT_SECONDS ?? "600", 10);
  const timeoutMs = Number.isInteger(reviewTimeout) && reviewTimeout > 0 ? reviewTimeout * 1000 : 600_000;

  let codexResult = buildFallback("Codex review skipped: codex CLI unavailable or unauthenticated.", {
    source: "codex",
  });
  let codexStatus = "skipped";

  const codexAvailable = commandExists("codex");
  const codexAuth = codexAvailable ? run("codex", ["login", "status"]) : { status: 1 };
  if (codexAvailable && codexAuth.status === 0) {
    const codexRun = run(
      "codex",
      ["exec", "--output-schema", schemaPath, "-o", tmpCodexPath, "-"],
      { input: prompt, timeout: timeoutMs, maxBuffer: 20 * 1024 * 1024 },
    );

    if (codexRun.status === 0 && existsSync(tmpCodexPath)) {
      try {
        const raw = await readFile(tmpCodexPath, "utf8");
        const parsed = JSON.parse(raw);
        codexResult = {
          schema_version: 2,
          summary: typeof parsed?.summary === "string" && parsed.summary.trim() ? parsed.summary.trim() : "Codex review complete.",
          findings: Array.isArray(parsed?.findings) ? parsed.findings : [],
          metadata: parsed?.metadata && typeof parsed.metadata === "object" ? parsed.metadata : {},
        };
        codexStatus = "ok";
      } catch (error) {
        codexResult = buildFallback(`Codex review output parse failed: ${error.message}`, { source: "codex" });
        codexStatus = "failed";
      }
    } else {
      codexResult = buildFallback("Codex review command failed or timed out.", { source: "codex" });
      codexStatus = "failed";
    }
  }

  try {
    await rm(tmpCodexPath, { force: true });
  } catch {
    // no-op
  }

  const localEnabled = (process.env.CODEX_REVIEW_OLLAMA_ENABLED ?? "1") !== "0";
  const localUrl = process.env.CODEX_REVIEW_OLLAMA_URL ?? "http://127.0.0.1:11434/v1/chat/completions";
  const localModel = process.env.CODEX_REVIEW_OLLAMA_MODEL ?? "qwen3.5:35b-a3b";
  const localTimeoutSec = Number.parseInt(process.env.CODEX_REVIEW_OLLAMA_TIMEOUT_SECONDS ?? "300", 10);
  const localTimeoutMs = Number.isInteger(localTimeoutSec) && localTimeoutSec > 0 ? localTimeoutSec * 1000 : 300_000;

  let localResult = buildFallback("Qwen local review skipped.", { source: "qwen" });
  let localStatus = "skipped";

  if (localEnabled) {
    try {
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), localTimeoutMs);
      const response = await fetch(localUrl, {
        method: "POST",
        signal: controller.signal,
        headers: {
          "Content-Type": "application/json",
          ...(process.env.CODEX_REVIEW_OLLAMA_API_KEY
            ? { Authorization: `Bearer ${process.env.CODEX_REVIEW_OLLAMA_API_KEY}` }
            : {}),
        },
        body: JSON.stringify({
          model: localModel,
          messages: [
            { role: "system", content: "You are a strict code reviewer that returns valid JSON only." },
            { role: "user", content: prompt },
          ],
          temperature: 0.1,
        }),
      });
      clearTimeout(timeoutId);

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`);
      }

      const payload = await response.json();
      const content = String(payload?.choices?.[0]?.message?.content ?? "");
      const jsonText = extractJsonObject(content);
      const parsed = JSON.parse(jsonText);
      localResult = {
        schema_version: 2,
        summary: typeof parsed?.summary === "string" && parsed.summary.trim() ? parsed.summary.trim() : "Qwen review complete.",
        findings: Array.isArray(parsed?.findings) ? parsed.findings : [],
        metadata: parsed?.metadata && typeof parsed.metadata === "object" ? parsed.metadata : {},
      };
      localStatus = "ok";
    } catch (error) {
      localResult = buildFallback(`Qwen local review failed: ${error.message}`, { source: "qwen" });
      localStatus = "failed";
    }
  }

  const findings = dedupeFindings([
    ...(Array.isArray(codexResult.findings)
      ? codexResult.findings.map((finding, index) => normalizeFinding(finding, index, "codex-cli")).filter(Boolean)
      : []),
    ...(Array.isArray(localResult.findings)
      ? localResult.findings.map((finding, index) => normalizeFinding(finding, index, `ollama:${localModel}`)).filter(Boolean)
      : []),
  ]);

  const summary = [
    `Review complete for ${args.sha}.`,
    `Codex: ${codexStatus}.`,
    `Qwen: ${localStatus}.`,
    `Findings: ${findings.length}.`,
  ].join(" ");

  const output = {
    schema_version: 2,
    summary,
    findings,
    metadata: {
      trigger: args.trigger,
      generated_at: new Date().toISOString(),
      codex_status: codexStatus,
      qwen_status: localStatus,
      local_model: localModel,
    },
  };

  await writeFile(jsonPath, `${JSON.stringify(output, null, 2)}\n`, "utf8");
  const verify = run("node", ["scripts/codex-review-verify-findings.mjs", "--json", jsonPath], {
    cwd: repoRoot,
  });
  if (verify.status === 0 && verify.stdout) {
    await writeFile(jsonPath, verify.stdout, "utf8");
  }

  await writeMarkdown(mdPath, args.sha, output.summary, output.findings, output.metadata);
  process.stderr.write(
    `[codex-review-commit] sha=${args.sha} trigger=${args.trigger} codex=${codexStatus} qwen=${localStatus} findings=${findings.length}\n`,
  );
}

main().catch((error) => {
  console.error(`[codex-review-commit] ${error.message}`);
  process.exit(1);
});
