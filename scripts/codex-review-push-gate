#!/usr/bin/env node

import { readFile } from "node:fs/promises";
import path from "node:path";
import { pathToFileURL } from "node:url";
import { defaultGitExec, executePushGate, parseMinSeverity } from "./codex-review-push-gate-lib.mjs";

function usage() {
  console.log(`Usage: scripts/codex-review-push-gate --stdin-file <path> [options]

Options:
  --stdin-file <path>         Required pre-push stdin capture file
  --remote-name <name>        Optional remote name
  --reviews-dir <path>        Override review artifact directory
  --min-severity <minor|major|blocker|none>
  --sync-missing <0|1>
`);
}

function parseArgs(argv) {
  const args = {
    stdinFile: "",
    remoteName: "",
    reviewsDir: "",
    minSeverity: parseMinSeverity(process.env.CODEX_REVIEW_PUSH_GATE_MIN_SEVERITY ?? "major"),
    syncMissing: (process.env.CODEX_REVIEW_PUSH_GATE_SYNC_MISSING ?? "1") !== "0",
  };

  for (let i = 2; i < argv.length; i += 1) {
    const arg = argv[i];
    const next = argv[i + 1];

    switch (arg) {
      case "--stdin-file":
        args.stdinFile = String(next ?? "");
        i += 1;
        break;
      case "--remote-name":
        args.remoteName = String(next ?? "");
        i += 1;
        break;
      case "--reviews-dir":
        args.reviewsDir = String(next ?? "");
        i += 1;
        break;
      case "--min-severity":
        args.minSeverity = parseMinSeverity(next ?? "major");
        i += 1;
        break;
      case "--sync-missing":
        args.syncMissing = String(next ?? "1") !== "0";
        i += 1;
        break;
      case "-h":
      case "--help":
        usage();
        process.exit(0);
        break;
      default:
        throw new Error(`Unknown argument: ${arg}`);
    }
  }

  if (!args.stdinFile) {
    throw new Error("--stdin-file is required");
  }

  return args;
}

function remediationHint(entry) {
  if (entry.reason === "review-report-missing") {
    return `next: generate review with scripts/codex-review-commit --sha ${entry.sha} --trigger manual`;
  }
  if (String(entry.reason).startsWith("severity-threshold-")) {
    return "next: resolve findings in .codex/reviews/*.md/.json or use emergency bypass once";
  }
  return "next: inspect .codex/reviews artifacts";
}

async function main() {
  if ((process.env.CODEX_REVIEW_ENABLED ?? "1") === "0") {
    console.log("[codex-review-push-gate] disabled (CODEX_REVIEW_ENABLED=0)");
    return;
  }

  if ((process.env.CODEX_REVIEW_PUSH_GATE_ENABLED ?? "1") === "0") {
    console.log("[codex-review-push-gate] disabled (CODEX_REVIEW_PUSH_GATE_ENABLED=0)");
    return;
  }

  if ((process.env.CODEX_REVIEW_PUSH_GATE_BYPASS ?? "0") === "1") {
    console.log("[codex-review-push-gate] WARNING: bypass enabled (CODEX_REVIEW_PUSH_GATE_BYPASS=1)");
    return;
  }

  const args = parseArgs(process.argv);
  const repoRoot = process.cwd();
  const stdinText = await readFile(args.stdinFile, "utf8");
  const reviewsDir = args.reviewsDir || path.join(repoRoot, ".codex", "reviews");

  const result = await executePushGate({
    repoRoot,
    reviewsDir,
    stdinText,
    minSeverity: args.minSeverity,
    syncMissing: args.syncMissing,
    gitExec: (gitArgs) => defaultGitExec(gitArgs, repoRoot),
  });

  if (result.summary.blocked > 0) {
    console.error(`[codex-review-push-gate] FAIL blocked=${result.summary.blocked}`);
    for (const entry of result.blocked) {
      console.error(
        `- ${entry.sha} status=${entry.status} severity=${entry.severity} findings=${entry.findings} reason=${entry.reason}`,
      );
      console.error(`  ${remediationHint(entry)}`);
    }
    process.exit(1);
  }

  console.log(
    `[codex-review-push-gate] PASS shas=${result.summary.shas} actionable=${result.summary.actionable} blocked=${result.summary.blocked}`,
  );
}

if (import.meta.url === pathToFileURL(path.resolve(process.argv[1] ?? "")).href) {
  main().catch((error) => {
    console.error(`[codex-review-push-gate] ${error.message}`);
    process.exit(1);
  });
}
